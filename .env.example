# ─────────────────────────────────────────────────────────────────
#  Firebase 設定（從 Firebase Console → 專案設定 → 您的應用程式 取得）
# ─────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# EdgeOne 環境變數（可選）
# - 建議直接使用上方 VITE_FIREBASE_* 原始 key 名稱
# - 若平台限制前綴，也可改填 FIREBASE_* 或 EDGEONE_FIREBASE_*
# FIREBASE_API_KEY=your_api_key_here
# FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# FIREBASE_APP_ID=your_app_id

# ─────────────────────────────────────────────────────────────────
#  Arduino / ESP8266 設定說明
#  請在 arduino/rfid_us_oled_dht11_wifi_fan.ino 中修改以下常數：
#
#  #define WIFI_SSID         "你的 WiFi 名稱"
#  #define WIFI_PASS         "你的 WiFi 密碼"
#  #define FIREBASE_HOST     "your_project_id-default-rtdb.<region>.firebasedatabase.app"
#  #define FIREBASE_HOST_IP  "35.186.xxx.xxx"   // 可選：給舊版 ESP8266 AT 韌體做 fallback
#  #define FIREBASE_AUTH     "你的 Firebase ID Token（通常可留空）"
#                            （你目前 rules 的 sensors / rfidScans 為 .write:true，可留空）
#  #define DEVICE_ID         "arduino-mega-01"
#
#  注意：Firebase Realtime Database 必須走 HTTPS/TLS。
#  舊版 ESP8266 AT（如 1.1.0）可能在主機名稱連線時出現 "IP ERROR"，
#  可啟用 FIREBASE_HOST_IP fallback（但 IP 變動時要同步更新）。
# ─────────────────────────────────────────────────────────────────
